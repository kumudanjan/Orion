# ============================================================
# Log Intelligence Assistant — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- LLM (Azure OpenAI — preferred) ---

AZURE_OPENAI_ENDPOINT = "https://log-intelligence-1.openai.azure.com/openai/deployments/gpt-4o-mini/chat/completions?api-version=2025-01-01-preview"
AZURE_OPENAI_KEY = "9OchFPHShSQbRUXGQml66uMjGQmnfhiary0SWK2AL4G5HX4DfDZMJQQJ99CCACYeBjFXJ3w3AAABACOGCUNO"
AZURE_OPENAI_DEPLOYMENT = "gpt-4o-mini"
AZURE_OPENAI_API_VERSION = "2024-12-01-preview"

# --- LLM (OpenAI — fallback) ---


# --- Vector DB ---
VECTOR_DB_TYPE=chroma          # chroma (local) or azure_search
CHROMA_PERSIST_DIR=./data/chroma

# Azure AI Search (if VECTOR_DB_TYPE=azure_search)
AZURE_SEARCH_ENDPOINT=https://YOUR_SEARCH.search.windows.net
AZURE_SEARCH_KEY=your_search_key_here
AZURE_SEARCH_INDEX=log-index

# --- Observability ---
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx

# --- RAI Guardrails ---
ENABLE_PII_MASKING=true
ENABLE_PROFANITY_FILTER=true

# --- Log Ingestion ---
MAX_LOG_FILE_SIZE_MB=50
CHUNK_SIZE=512
CHUNK_OVERLAP=64
